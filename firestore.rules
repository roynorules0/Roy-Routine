rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Global Safety Net - Default Deny everything
    match /{document=**} {
      allow read, write: if false;
    }

    // Common helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // Entity Validations
    function isValidUser(data) {
      return data.uid is string && data.uid.size() <= 128 &&
             data.email is string && data.email.size() <= 200 &&
             data.displayName is string && data.displayName.size() <= 150 &&
             data.points is int &&
             data.streak is int &&
             data.maxStreak is int &&
             data.currentMood is string && data.currentMood.size() <= 50 &&
             data.guardianRank is string && data.guardianRank.size() <= 50;
    }

    function isValidTask(data) {
      return data.id is string && data.id.size() <= 128 &&
             data.title is string && data.title.size() <= 200 &&
             data.category is string && data.category.size() <= 50 &&
             data.time is string && data.time.size() <= 20 &&
             data.points is int &&
             data.completed is bool &&
             data.date is string && data.date.size() <= 15;
    }

    // Rules for User Profile collection
    match /users/{userId} {
      allow get: if isSignedIn();
      // Allow list for the Leaderboard
      allow list: if isSignedIn();
      
      // Allow creation of own profile
      allow create: if isOwner(userId) && isValidUser(incoming()) && incoming().uid == request.auth.uid;
      
      // Allow updates to own profile
      allow update: if isOwner(userId) && isValidUser(incoming()) && incoming().uid == existing().uid;
      
      // Prevent deleting profiles
      allow delete: if false;

      // Rules for Tasks sub-collection
      match /tasks/{taskId} {
        allow read: if isOwner(userId);
        
        allow create: if isOwner(userId) && isValidId(taskId) && isValidTask(incoming());
        
        allow update: if isOwner(userId) && isValidId(taskId) && isValidTask(incoming());
        
        allow delete: if isOwner(userId) && isValidId(taskId);
      }
    }
  }
}
